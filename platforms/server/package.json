{
  "name": "@nse-dev/server",
  "version": "0.1.0",
  "description": "Server-side Nostr Secure Enclave — process keypairs for relays, blossom, MCP",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cloudflare": {
      "import": "./dist/cloudflare.js",
      "types": "./dist/cloudflare.d.ts"
    },
    "./node": {
      "import": "./dist/node.js",
      "types": "./dist/node.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["nostr", "secure-enclave", "key-management", "server", "cloudflare-workers"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HumanjavaEnterprises/nse-dev.web.landingpage.src",
    "directory": "platforms/server"
  },
  "dependencies": {
    "nostr-crypto-utils": "^0.7.0",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
